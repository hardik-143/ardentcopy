{
  "name": "arden-carpet",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "dev:studio": "sanity dev",
    "build:studio": "node scripts/sync-preview-svg-tokens-from-globals.mjs && sanity build studio/dist --yes",
