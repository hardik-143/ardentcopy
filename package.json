    "extract": "sanity schema extract --enforce-required-fields",
    "type": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "postinstall": "sanity exec studio/scripts/cli-alert-for-data.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check-types": "tsc --noEmit",
    "sync:preview-svgs": "node scripts/sync-preview-svg-tokens-from-globals.mjs"
  },
